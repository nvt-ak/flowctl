{
  "name": "@cursor-kit/flowctl",
  "version": "0.0.9",
  "type": "module",
  "description": "Workflow Orchestration for Cursor",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvt-ak/flowctl.git"
  },
  "author": "Tai Nguyen Van",
  "license": "MIT",
  "homepage": "https://github.com/nvt-ak/flowctl",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "keywords": [
    "flowctl",
    "workflow",
    "mcp",
    "cursor",
    "workflow-orchestration",
    "workflow-orchestration-mcp",
    "workflow-orchestration-mcp-server",
    "workflow-orchestration-mcp-server-shell-proxy",
    "workflow-orchestration-mcp-server-workflow-state",
    "shell-proxy",
    "workflow-state"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "src",
    "dist/flowctl-*",
    "scripts/flowctl.sh",
    "scripts/setup.sh",
    "scripts/merge_cursor_mcp.py",
    "scripts/monitor-web.py",
    "scripts/token-audit.py",
    "scripts/hooks",
    "scripts/workflow",
    "templates",
    "workflows/dispatch",
    "workflows/gates",
    "workflows/policies",
    ".cursor/agents",
    ".cursor/commands",
    ".cursor/rules",
    ".cursor/skills",
    ".cursorrules"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run setup-hooks"
    }
  },
  "bin": {
    "flowctl": "bin/flowctl"
  },
  "scripts": {
    "setup-hooks": "bun run src/hooks/setup.ts",
    "flowctl": "flowctl",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli/index.ts --compile --outfile dist/flowctl",
    "build:linux-x64": "bun build src/cli/index.ts --compile --target=bun-linux-x64 --outfile dist/flowctl-linux-x64",
    "build:linux-arm64": "bun build src/cli/index.ts --compile --target=bun-linux-arm64 --outfile dist/flowctl-linux-arm64",
    "build:darwin-x64": "bun build src/cli/index.ts --compile --target=bun-darwin-x64 --outfile dist/flowctl-darwin-x64",
    "build:darwin-arm64": "bun build src/cli/index.ts --compile --target=bun-darwin-arm64 --outfile dist/flowctl-darwin-arm64",
    "build:windows-x64": "bun build src/cli/index.ts --compile --target=bun-windows-x64 --outfile dist/flowctl-win-x64.exe",
    "build:all": "concurrently -c auto -m 4 \"npm run build:linux-x64\" \"npm run build:linux-arm64\" \"npm run build:darwin-x64\" \"npm run build:darwin-arm64\" \"npm run build:windows-x64\"",
    "test:unit": "bun vitest run test/unit",
    "test:integration": "bun vitest run test/integration --passWithNoTests",
    "test:e2e:vitest": "bun vitest run test/e2e",
    "test:python": "python3 -m pytest tests/ -q",
    "test:legacy": "bash test/test-package-files.sh && bash test/test-merge-cursor-mcp.sh && bash test/test-workflow-tdd-regression.sh && bash test/test-complexity-war-room.sh",
    "test": "bun vitest run --coverage",
    "ci:gate": "npm run typecheck && npm run test:unit && npm run test:integration",
    "ci": "npm run ci:gate && npm run test:python && npm run test:legacy",
    "test:package": "bash test/test-package-files.sh",
    "test:merge-mcp": "bash test/test-merge-cursor-mcp.sh",
    "test:tdd": "bash test/test-workflow-tdd-regression.sh",
    "test:e2e": "bash test/test-workflow-e2e.sh",
    "test:gate:local": "bun run src/hooks/quality-gate.ts -- --mode local",
    "test:ci": "bun run src/hooks/quality-gate.ts -- --mode ci",
    "test:complexity": "bash test/test-complexity-war-room.sh",
    "test:ci:core": "npm run test:package && npm run test:merge-mcp && npm run test:tdd && npm run test:fixes && npm run test:complexity",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release:push": "git push -u origin HEAD --follow-tags",
    "prepare": "husky",
    "test:fixes": "bash test/test-workflow-fixes.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "bugs": {
    "url": "https://github.com/nvt-ak/flowctl/issues"
  }
}
